{
  "description": "Vigil change-tracker: semantic diff compression after every file write",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use/track-change.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
